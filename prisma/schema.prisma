// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id           Int           @id @default(autoincrement())
  nome         String
  itensEstoque ItemEstoque[]
}

model Minerio {
  id           Int           @id @default(autoincrement())
  nome         String
  itensEstoque ItemEstoque[]
  extracoes    Extracao[]
}

model Estoque {
  id    Int           @id @default(autoincrement())
  itens ItemEstoque[]
}

model ItemEstoque {
  id         Int      @id @default(autoincrement())
  quantidade Int

  produtoId  Int?
  produto    Produto? @relation(fields: [produtoId], references: [id])

  minerioId  Int?
  minerio    Minerio? @relation(fields: [minerioId], references: [id])

  estoqueId  Int
  estoque    Estoque  @relation(fields: [estoqueId], references: [id])
}

model Compra {
  id         Int @id @default(autoincrement())
  produtoId  Int
  quantidade Int
}

model Extracao {
  id         Int      @id @default(autoincrement())
  minerioId  Int
  minerio    Minerio  @relation(fields: [minerioId], references: [id])
  quantidade Int
  criadoEm   DateTime @default(now())
}

model Venda {
  id         Int @id @default(autoincrement())
  minerioId  Int
  quantidade Int
}

model Usuario {
  id        Int    @id @default(autoincrement())
  usuario   String @unique
  senhaHash String
}
